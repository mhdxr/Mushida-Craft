# Nomor WhatsApp tujuan order (format internasional tanpa "+", contoh: 6281234567890)
NEXT_PUBLIC_WHATSAPP_NUMBER=6281234567890

# Kredensial admin dashboard
# WAJIB diisi sebelum deploy — jangan biarkan kosong di produksi.
# Password minimal 12 karakter, kuat & unik (disarankan 16+ karakter acak).
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Secret penandatangan sesi admin (WAJIB, RAHASIA, server-only; gunakan nilai acak yang kuat)
SESSION_SECRET=

# URL produksi situs (untuk SEO & metadata)
NEXT_PUBLIC_SITE_URL=https://Mushida.vercel.app

# ── Supabase (backend database produk) ──
# Dapatkan di: Supabase Dashboard > Project Settings > API
# URL & anon key (public, aman di-expose ke browser — RLS membatasi ke SELECT)
# URL juga dipakai untuk allowlist gambar Supabase Storage di next/image.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (RAHASIA — hanya untuk server/API routes, bypass RLS)
# Jangan pernah expose ke browser atau commit ke git.
SUPABASE_SERVICE_ROLE_KEY=
# Connection string database (untuk npm run db:setup — jalankan migration otomatis)
# Dapatkan di: Dashboard > Project Settings > Database > Connection string > URI
SUPABASE_DB_URL=

# ── Sentry (opsional — kosongkan untuk menonaktifkan error tracking) ──
# DSN public (aman di-expose ke browser). Dapatkan di Project Settings > Client Keys.
NEXT_PUBLIC_SENTRY_DSN=
# Auth token untuk upload source maps saat build (RAHASIA — jangan commit .env).
# Dapatkan di Account Settings > Auth Tokens.
SENTRY_AUTH_TOKEN=
# Slug organisasi & project Sentry Anda.
SENTRY_ORG=
SENTRY_PROJECT=

# ── PostHog (analytics — opsional, kosongkan untuk menonaktifkan) ──
# Public key (aman di-expose ke browser). Dapatkan di Project Settings > API Key.
NEXT_PUBLIC_POSTHOG_KEY=
# Host PostHog (default: US cloud). EU cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Upstash Redis (rate limit login admin — disarankan di production) ──
# Dapatkan di: https://console.upstash.com → Create Database → REST API
# Jika kosong, rate limit fallback ke Map in-memory (tidak terdistribusi).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
