# Nomor WhatsApp tujuan order (format internasional tanpa "+", contoh: 6281234567890)
NEXT_PUBLIC_WHATSAPP_NUMBER=6285713254800

# Kredensial admin dashboard
# WAJIB diisi sebelum deploy — jangan biarkan kosong di produksi.
# Password minimal 12 karakter, kuat & unik (disarankan 16+ karakter acak).
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Secret penandatangan sesi admin (WAJIB, RAHASIA, server-only; gunakan nilai acak yang kuat)
SESSION_SECRET=

# URL produksi situs (untuk SEO & metadata)
NEXT_PUBLIC_SITE_URL=https://mushida-craft.vercel.app

# Kartu promo di hero homepage (opsional — kosongkan untuk pakai default).
# Nilai di-inline saat build; ganti env lalu redeploy untuk memperbarui.
NEXT_PUBLIC_HERO_PROMO_LABEL=Promo bulan ini
NEXT_PUBLIC_HERO_PROMO_TEXT=Free greeting card 💌
# Foto hero (opsional). Jika kosong: pakai gambar produk unggulan, lalu fallback bawaan.
NEXT_PUBLIC_HERO_IMAGE_URL=
NEXT_PUBLIC_HERO_IMAGE_ALT=
# Social proof hero (opsional). Rating real dihitung dari testimoni approved.
NEXT_PUBLIC_HERO_DELIVERED_COUNT=500+
NEXT_PUBLIC_HERO_DELIVERY_TIME=3 Jam
NEXT_PUBLIC_HERO_RATING_FALLBACK=4.9★

# Area layanan & cut-off same-day (opsional — isi agar copy pengiriman spesifik).
NEXT_PUBLIC_SERVICE_CITY=Jakarta Barat
NEXT_PUBLIC_SERVICE_AREAS=Jakarta Barat,Jakarta Pusat
NEXT_PUBLIC_SAME_DAY_CUTOFF=15:00
NEXT_PUBLIC_BUSINESS_HOURS=Senin–Sabtu · 09.00–18.00 WIB
# Contoh: Pickup by appointment di studio
NEXT_PUBLIC_PICKUP_NOTE=

# ── Supabase (backend database produk) ──
# Dapatkan di: Supabase Dashboard > Project Settings > API
# URL & anon key (public, aman di-expose ke browser — RLS membatasi ke SELECT)
# URL juga dipakai untuk allowlist gambar Supabase Storage di next/image.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (RAHASIA — hanya untuk server/API routes, bypass RLS)
# Jangan pernah expose ke browser atau commit ke git.
SUPABASE_SERVICE_ROLE_KEY=
# Connection string database (untuk npm run db:setup — jalankan migration otomatis)
# Dapatkan di: Dashboard > Project Settings > Database > Connection string > URI
SUPABASE_DB_URL=
# Opsional: set 1 hanya jika SSL ke pooler Supabase gagal di Windows
# (default sekarang ketat — rejectUnauthorized:true).
# DB_SSL_INSECURE=1

# ── Sentry (opsional — kosongkan untuk menonaktifkan error tracking) ──
# DSN public (aman di-expose ke browser). Dapatkan di Project Settings > Client Keys.
NEXT_PUBLIC_SENTRY_DSN=
# Auth token untuk upload source maps saat build (RAHASIA — jangan commit .env).
# Dapatkan di Account Settings > Auth Tokens.
SENTRY_AUTH_TOKEN=
# Slug organisasi & project Sentry Anda.
SENTRY_ORG=
SENTRY_PROJECT=

# ── PostHog (analytics — opsional, kosongkan untuk menonaktifkan) ──
# Public key (aman di-expose ke browser). Dapatkan di Project Settings > API Key.
NEXT_PUBLIC_POSTHOG_KEY=
# Host PostHog (default: US cloud). EU cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Upstash Redis (rate limit — WAJIB di production / Vercel multi-instance) ──
# Login admin, submit testimoni, log inquiry WA.
# Dapatkan di: https://console.upstash.com → Create Database → REST API
# Dev lokal: boleh kosong → fallback Map in-memory (per proses).
# Production tanpa ini: GET /api/health → status "degraded".
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Notifikasi admin (opsional — email via Resend) ──
# Kosongkan = no-op (aman di dev). Dapatkan key: https://resend.com → API Keys.
# RESEND_FROM: domain verified di Resend (prod). Default dev: onboarding@resend.dev
# (hanya bisa kirim ke email akun Resend sendiri).
RESEND_API_KEY=
RESEND_FROM=Mushida Craft <onboarding@resend.dev>
# Tujuan email (default: ADMIN_EMAIL bila kosong)
ADMIN_NOTIFY_EMAIL=
